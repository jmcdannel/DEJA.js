{
  "extends": "@repo/typescript-config/base.json",
  "include": ["./**/*", "./**/*.json"],
  "exclude": ["dist", "build", "node_modules"],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  }
}
