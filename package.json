{
  "name": "deja",
  "version": "1.2.0",
  "private": true,
  "description": "",
  "author": "",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:format": "syncpack format",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "start": "turbo run start --filter=deja-serverts",
    "start:all": "turbo run start",
    "deja": "bash scripts/deja.sh",
    "scan-sounds": "turbo run scan-sounds --filter=@repo/sounds",
    "changeset": "changeset",
    "changeset:status": "changeset status"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "npm-run-all": "^4.1.5",
    "pm2": "^5.4.2",
    "syncpack": "^13.0.4",
    "turbo": "^2.5.3"
  },
  "keywords": [],
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "pg-protocol": "^1.13.0",
    "pg-types": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.11"
    }
  }
