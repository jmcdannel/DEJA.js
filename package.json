{
  "name": "deja",
  "version": "1.5.0",
  "private": true,
  "description": "",
  "author": "",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run type-check",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:format": "syncpack format",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "start": "turbo run start --filter=deja-serverts",
    "start:all": "turbo run start",
    "deja": "bash apps/cli/deja",
    "layout": "bash scripts/switch-layout.sh",
    "scan-sounds": "turbo run scan-sounds --filter=@repo/sounds",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "promo:push": "tsx scripts/push-promo.ts",
    "promo:deactivate": "tsx scripts/push-promo.ts --deactivate",
    "demo:seed": "tsx scripts/demo/seed-firestore.ts",
    "dev:demo": "VITE_AUTO_LOGIN=true turbo run dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@sanity/client": "6",
    "dotenv": "^16.3.1",
    "firebase-admin": "^13.4.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.44.0",
    "pm2": "^5.4.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "syncpack": "^13.0.4",
    "turbo": "^2.5.3"
  },
  "keywords": [],
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "pg-protocol": "^1.13.0",
    "pg-types": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.11",
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  }
}
