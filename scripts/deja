#!/usr/bin/env bash
# scripts/deja — DEJA.js Server CLI
# Manages the DEJA.js server as a native Node.js process.
# Install location: ~/.deja/bin/deja

set -euo pipefail

DEJA_DIR="${HOME}/.deja"
SERVER_DIR="${DEJA_DIR}/server"
PID_FILE="${DEJA_DIR}/server.pid"
LOG_DIR="${DEJA_DIR}/logs"
LOG_FILE="${LOG_DIR}/server.log"
VERSION_FILE="${SERVER_DIR}/version.txt"
CONFIG_FILE="${DEJA_DIR}/config.json"
ENV_FILE="${DEJA_DIR}/.env"
ENTRY="${SERVER_DIR}/dist/index.js"
GITHUB_REPO="jmcdannel/DEJA.js"

# Max log file size before rotation (10MB)
MAX_LOG_SIZE=10485760

# --- Colors & Styles ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Icons (Unicode) ---
ICON_SERVER="⚡"
ICON_RUNNING="●"
ICON_STOPPED="○"
ICON_SERIAL="🔌"
ICON_WS="🌐"
ICON_TRAIN="🚂"
ICON_CHECK="✔"
ICON_CROSS="✖"
ICON_WARN="▲"
ICON_ARROW="→"
ICON_CLOUD="☁"
ICON_THROTTLE="🎮"
ICON_MONITOR="📊"
ICON_UPDATE="↻"
ICON_LOG="📋"
ICON_CONFIG="⚙"

info()  { echo -e "  ${BLUE}${ICON_ARROW}${NC} $*"; }
ok()    { echo -e "  ${GREEN}${ICON_CHECK}${NC} $*"; }
warn()  { echo -e "  ${YELLOW}${ICON_WARN}${NC} $*"; }
err()   { echo -e "  ${RED}${ICON_CROSS}${NC} $*" >&2; }

# ======================================================================
# Helpers
# ======================================================================

get_version() {
  if [ -f "${VERSION_FILE}" ]; then
    cat "${VERSION_FILE}"
  else
    echo "unknown"
  fi
}

is_running() {
  if [ -f "${PID_FILE}" ]; then
    local pid
    pid=$(cat "${PID_FILE}")
    if kill -0 "${pid}" 2>/dev/null; then
      return 0
    else
      # Stale PID file
      rm -f "${PID_FILE}"
      return 1
    fi
  fi
  return 1
}

get_pid() {
  if [ -f "${PID_FILE}" ]; then
    cat "${PID_FILE}"
  fi
}

rotate_log() {
  if [ -f "${LOG_FILE}" ]; then
    local size
    size=$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)
    if [ "${size}" -gt "${MAX_LOG_SIZE}" ]; then
      mv "${LOG_FILE}" "${LOG_FILE}.1"
    fi
  fi
}

check_installed() {
  if [ ! -f "${ENTRY}" ]; then
    err "DEJA.js server is not installed."
    err "Run the installer: curl -fsSL https://install.dejajs.com | bash"
    exit 1
  fi
}

check_env() {
  if [ ! -f "${ENV_FILE}" ]; then
    warn "No .env file found at ${ENV_FILE}"
    warn "The server may not start correctly without environment configuration."
  fi
}

# ======================================================================
# Commands
# ======================================================================

cmd_start() {
  check_installed

  if is_running; then
    local pid
    pid=$(get_pid)
    ok "Server is already running ${DIM}(PID ${pid})${NC}"
    return 0
  fi

  check_env
  rotate_log
  mkdir -p "${LOG_DIR}"

  info "Starting DEJA.js server..."

  # CWD must be ~/.deja so dotenv/config finds .env
  cd "${DEJA_DIR}"
  nohup node "${ENTRY}" >> "${LOG_FILE}" 2>&1 &
  local pid=$!
  echo "${pid}" > "${PID_FILE}"

  # Verify the process started
  sleep 1
  if kill -0 "${pid}" 2>/dev/null; then
    echo ""
    echo -e "  ${GREEN}${ICON_SERVER} Server started${NC} ${DIM}(PID ${pid})${NC}"
    echo ""
    echo -e "    ${DIM}Version${NC}   $(get_version)"
    echo -e "    ${DIM}Logs${NC}      deja logs -f"
    echo -e "    ${DIM}Status${NC}    deja status"
    echo ""
  else
    rm -f "${PID_FILE}"
    err "Server failed to start. Check logs:"
    echo -e "    ${LOG_FILE}"
    exit 1
  fi
}

cmd_stop() {
  if ! is_running; then
    warn "Server is not running."
    return 0
  fi

  local pid
  pid=$(get_pid)
  info "Stopping server ${DIM}(PID ${pid})${NC}..."

  # Graceful shutdown
  kill "${pid}" 2>/dev/null || true

  # Wait up to 12 seconds for graceful shutdown
  local waited=0
  while [ ${waited} -lt 12 ]; do
    if ! kill -0 "${pid}" 2>/dev/null; then
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done

  # Force kill if still running
  if kill -0 "${pid}" 2>/dev/null; then
    warn "Forcing shutdown..."
    kill -9 "${pid}" 2>/dev/null || true
    sleep 1
  fi

  rm -f "${PID_FILE}"
  ok "Server stopped."
}

cmd_restart() {
  cmd_stop
  cmd_start
}

cmd_status() {
  echo ""
  echo -e "  ${BOLD}${ICON_SERVER} DEJA.js Server${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"

  # Version
  local version
  version=$(get_version)
  echo -e "  ${DIM}Version${NC}     ${version}"

  # Process state
  if is_running; then
    local pid
    pid=$(get_pid)
    echo -e "  ${DIM}Status${NC}      ${GREEN}${ICON_RUNNING} running${NC} ${DIM}(PID ${pid})${NC}"
  else
    echo -e "  ${DIM}Status${NC}      ${RED}${ICON_STOPPED} stopped${NC}"
  fi

  # Config
  if [ -f "${CONFIG_FILE}" ]; then
    local uid layout_id
    uid=$(grep -o '"uid"[[:space:]]*:[[:space:]]*"[^"]*"' "${CONFIG_FILE}" | sed 's/.*"uid"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "")
    layout_id=$(grep -o '"layoutId"[[:space:]]*:[[:space:]]*"[^"]*"' "${CONFIG_FILE}" | sed 's/.*"layoutId"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "")
    if [ -n "${uid}" ]; then
      echo -e "  ${DIM}Account${NC}     ${uid}"
    fi
    if [ -n "${layout_id}" ]; then
      echo -e "  ${DIM}Layout${NC}      ${layout_id}"
    fi
  fi

  echo ""
  echo -e "  ${BOLD}${ICON_CONFIG} Connections${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"

  # WebSocket
  if [ -f "${ENV_FILE}" ]; then
    local ws_port ws_enabled
    ws_port=$(grep '^VITE_WS_PORT=' "${ENV_FILE}" | cut -d'=' -f2 || echo "8082")
    ws_port="${ws_port:-8082}"
    ws_enabled=$(grep '^ENABLE_WS=' "${ENV_FILE}" | cut -d'=' -f2 || echo "true")
    ws_enabled="${ws_enabled:-true}"
    if [ "${ws_enabled}" != "false" ]; then
      echo -e "  ${ICON_WS} ${DIM}WebSocket${NC}   ${CYAN}ws://localhost:${ws_port}${NC}"
    else
      echo -e "  ${ICON_WS} ${DIM}WebSocket${NC}   ${DIM}disabled${NC}"
    fi

    # MQTT
    local mqtt_enabled
    mqtt_enabled=$(grep '^ENABLE_MQTT=' "${ENV_FILE}" | cut -d'=' -f2 || echo "false")
    mqtt_enabled="${mqtt_enabled:-false}"
    if [ "${mqtt_enabled}" = "true" ]; then
      echo -e "  ${ICON_CLOUD} ${DIM}MQTT${NC}        ${GREEN}enabled${NC}"
    fi

    # Cloud
    local cloud_enabled
    cloud_enabled=$(grep '^ENABLE_DEJACLOUD=' "${ENV_FILE}" | cut -d'=' -f2 || echo "false")
    cloud_enabled="${cloud_enabled:-false}"
    if [ "${cloud_enabled}" = "true" ]; then
      echo -e "  ${ICON_CLOUD} ${DIM}DEJA Cloud${NC}  ${GREEN}connected${NC}"
    fi
  fi

  # Serial ports
  local ports=()
  for p in /dev/ttyUSB* /dev/ttyACM* /dev/ttyAMA* /dev/tty.usbmodem* /dev/tty.usbserial*; do
    [ -e "${p}" ] && ports+=("${p}")
  done
  if [ ${#ports[@]} -gt 0 ]; then
    for port in "${ports[@]}"; do
      echo -e "  ${ICON_SERIAL} ${DIM}Serial${NC}      ${port}"
    done
  else
    echo -e "  ${ICON_SERIAL} ${DIM}Serial${NC}      ${DIM}none detected${NC}"
  fi

  echo ""
  echo -e "  ${BOLD}${ICON_TRAIN} Apps${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  echo -e "  ${ICON_THROTTLE} ${DIM}Throttle${NC}    ${CYAN}https://throttle.dejajs.com${NC}"
  echo -e "  ${ICON_CLOUD} ${DIM}Cloud${NC}       ${CYAN}https://cloud.dejajs.com${NC}"
  echo -e "  ${ICON_MONITOR} ${DIM}Monitor${NC}     ${CYAN}https://monitor.dejajs.com${NC}"

  # Log file
  echo ""
  if [ -f "${LOG_FILE}" ]; then
    local log_size
    log_size=$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)
    if [ "${log_size}" -gt 1048576 ]; then
      echo -e "  ${ICON_LOG} ${DIM}Log${NC}  ${LOG_FILE} ${DIM}($((log_size / 1048576))MB)${NC}"
    elif [ "${log_size}" -gt 1024 ]; then
      echo -e "  ${ICON_LOG} ${DIM}Log${NC}  ${LOG_FILE} ${DIM}($((log_size / 1024))KB)${NC}"
    else
      echo -e "  ${ICON_LOG} ${DIM}Log${NC}  ${LOG_FILE} ${DIM}(${log_size}B)${NC}"
    fi
  fi

  echo ""
}

cmd_logs() {
  if [ ! -f "${LOG_FILE}" ]; then
    warn "No log file found."
    return 0
  fi

  local follow=false
  local lines=50

  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--follow) follow=true ;;
      -n|--lines)
        shift
        lines="${1:-50}"
        ;;
      -n*)
        lines="${1#-n}"
        ;;
      *) ;;
    esac
    shift
  done

  if [ "${follow}" = true ]; then
    tail -n "${lines}" -f "${LOG_FILE}"
  else
    tail -n "${lines}" "${LOG_FILE}"
  fi
}

cmd_update() {
  echo ""
  echo -e "  ${ICON_UPDATE} ${BOLD}Checking for updates...${NC}"

  local current_version
  current_version=$(get_version)

  # Fetch latest release info from GitHub
  local release_info
  release_info=$(curl -fsSL "https://api.github.com/repos/${GITHUB_REPO}/releases/latest" 2>/dev/null) || {
    err "Failed to check for updates. Check your internet connection."
    exit 1
  }

  local latest_version
  latest_version=$(echo "${release_info}" | grep '"tag_name"' | sed 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')

  if [ -z "${latest_version}" ]; then
    err "Could not determine latest version."
    exit 1
  fi

  if [ "${current_version}" = "${latest_version}" ]; then
    ok "Already up to date ${DIM}(${current_version})${NC}"
    echo ""
    return 0
  fi

  info "Updating: ${current_version} ${ICON_ARROW} ${latest_version}"

  # Check if server is running (will restart after update)
  local was_running=false
  if is_running; then
    was_running=true
    cmd_stop
  fi

  # Download tarball
  local tarball_url="https://github.com/${GITHUB_REPO}/releases/download/${latest_version}/deja-server.tar.gz"
  local tmp_dir
  tmp_dir=$(mktemp -d)

  info "Downloading ${latest_version}..."
  curl -fsSL "${tarball_url}" -o "${tmp_dir}/deja-server.tar.gz" || {
    err "Failed to download update."
    rm -rf "${tmp_dir}"
    exit 1
  }

  # Extract and replace
  info "Installing..."
  mkdir -p "${SERVER_DIR}"
  tar -xzf "${tmp_dir}/deja-server.tar.gz" -C "${SERVER_DIR}"
  rm -rf "${tmp_dir}"

  # Install/update native dependencies
  info "Installing dependencies..."
  cd "${SERVER_DIR}" && npm install --production --silent 2>/dev/null

  ok "Updated to ${latest_version}"

  # Restart if was running
  if [ "${was_running}" = true ]; then
    cmd_start
  fi
  echo ""
}

cmd_help() {
  echo ""
  echo -e "  ${BOLD}${ICON_SERVER} DEJA.js Server CLI${NC}"
  echo ""
  echo -e "  ${DIM}Usage:${NC} deja ${CYAN}<command>${NC} [options]"
  echo ""
  echo -e "  ${BOLD}Commands${NC}"
  echo -e "    ${CYAN}start${NC}          Start the server"
  echo -e "    ${CYAN}stop${NC}           Stop the server"
  echo -e "    ${CYAN}restart${NC}        Restart the server"
  echo -e "    ${CYAN}status${NC}         Show server status and connections"
  echo -e "    ${CYAN}logs${NC} [-f]      View server logs (-f to follow)"
  echo -e "    ${CYAN}update${NC}         Update to the latest version"
  echo ""
  echo -e "  ${BOLD}Options${NC}"
  echo -e "    ${DIM}--version${NC}      Show installed version"
  echo -e "    ${DIM}--help, -h${NC}     Show this help"
  echo ""
  echo -e "  ${ICON_CONFIG} Config  ${DIM}${DEJA_DIR}/${NC}"
  echo -e "  ${ICON_LOG} Logs    ${DIM}${LOG_FILE}${NC}"
  echo ""
}

# ======================================================================
# Main
# ======================================================================

case "${1:-}" in
  start)    shift; cmd_start "$@" ;;
  stop)     shift; cmd_stop "$@" ;;
  restart)  shift; cmd_restart "$@" ;;
  status)   shift; cmd_status "$@" ;;
  logs)     shift; cmd_logs "$@" ;;
  update)   shift; cmd_update "$@" ;;
  --version|-v)
    echo "deja $(get_version)"
    ;;
  --help|-h|help)
    cmd_help
    ;;
  "")
    cmd_help
    ;;
  *)
    err "Unknown command: $1"
    cmd_help
    exit 1
    ;;
esac
