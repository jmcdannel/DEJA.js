#!/usr/bin/env bash
# scripts/deja — DEJA.js Server CLI
# Manages the DEJA.js server as a native Node.js process.
# Install location: ~/.deja/bin/deja

set -euo pipefail

DEJA_DIR="${HOME}/.deja"
SERVER_DIR="${DEJA_DIR}/server"
PID_FILE="${DEJA_DIR}/server.pid"
LOG_DIR="${DEJA_DIR}/logs"
LOG_FILE="${LOG_DIR}/server.log"
VERSION_FILE="${SERVER_DIR}/version.txt"
CONFIG_FILE="${DEJA_DIR}/config.json"
ENV_FILE="${DEJA_DIR}/.env"
ENTRY="${SERVER_DIR}/index.js"
INSTALL_BASE_URL="https://install.dejajs.com"

# Tunnel
TUNNEL_PID_FILE="${DEJA_DIR}/tunnel.pid"
TUNNEL_LOG_FILE="${LOG_DIR}/tunnel.log"
TUNNEL_URL_FILE="${DEJA_DIR}/tunnel.url"
CLOUDFLARED_YML="${DEJA_DIR}/cloudflared.yml"

# Max log file size before rotation (10MB)
MAX_LOG_SIZE=10485760

# --- Colors & Styles ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Icons (Unicode) ---
ICON_SERVER="⚡"
ICON_RUNNING="●"
ICON_STOPPED="○"
ICON_SERIAL="🔌"
ICON_WS="🌐"
ICON_TRAIN="🚂"
ICON_CHECK="✔"
ICON_CROSS="✖"
ICON_WARN="▲"
ICON_ARROW="→"
ICON_CLOUD="☁"
ICON_THROTTLE="🎮"
ICON_MONITOR="📊"
ICON_UPDATE="↻"
ICON_LOG="📋"
ICON_CONFIG="⚙"
ICON_TUNNEL="🔒"

info()  { echo -e "  ${BLUE}${ICON_ARROW}${NC} $*"; }
ok()    { echo -e "  ${GREEN}${ICON_CHECK}${NC} $*"; }
warn()  { echo -e "  ${YELLOW}${ICON_WARN}${NC} $*"; }
err()   { echo -e "  ${RED}${ICON_CROSS}${NC} $*" >&2; }

# ======================================================================
# Helpers
# ======================================================================

get_version() {
  if [ -f "${VERSION_FILE}" ]; then
    cat "${VERSION_FILE}"
  else
    echo "unknown"
  fi
}

is_running() {
  if [ -f "${PID_FILE}" ]; then
    local pid
    pid=$(cat "${PID_FILE}")
    if kill -0 "${pid}" 2>/dev/null; then
      return 0
    else
      # Stale PID file
      rm -f "${PID_FILE}"
      return 1
    fi
  fi
  return 1
}

get_pid() {
  if [ -f "${PID_FILE}" ]; then
    cat "${PID_FILE}"
  fi
}

rotate_log() {
  if [ -f "${LOG_FILE}" ]; then
    local size
    size=$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)
    if [ "${size}" -gt "${MAX_LOG_SIZE}" ]; then
      mv "${LOG_FILE}" "${LOG_FILE}.1"
    fi
  fi
}

check_installed() {
  if [ ! -f "${ENTRY}" ]; then
    err "DEJA.js server is not installed."
    err "Run the installer: curl -fsSL https://install.dejajs.com | bash"
    exit 1
  fi
}

check_env() {
  if [ ! -f "${ENV_FILE}" ]; then
    warn "No .env file found at ${ENV_FILE}"
    warn "The server may not start correctly without environment configuration."
  fi
}

# ======================================================================
# Tunnel Helpers
# ======================================================================

check_cloudflared() {
  if ! command -v cloudflared &>/dev/null; then
    warn "cloudflared is not installed. Remote monitoring requires cloudflared."
    info "Install it:"
    echo -e "    ${DIM}macOS:${NC}  brew install cloudflare/cloudflare/cloudflared"
    echo -e "    ${DIM}Linux:${NC}  curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg | sudo tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null"
    echo -e "           ${DIM}echo 'deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared focal main' | sudo tee /etc/apt/sources.list.d/cloudflared.list${NC}"
    echo -e "           ${DIM}sudo apt-get update && sudo apt-get install cloudflared${NC}"
    echo -e "    ${DIM}Docs:${NC}   https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/"
    return 1
  fi
  return 0
}

get_plan() {
  if [ ! -f "${CONFIG_FILE}" ]; then
    echo ""
    return
  fi
  node -e "
    try {
      const c = JSON.parse(require('fs').readFileSync('${CONFIG_FILE}', 'utf8'));
      console.log(c.subscription?.plan || '');
    } catch(e) { console.log(''); }
  " 2>/dev/null || echo ""
}

is_paid_plan() {
  local plan
  plan=$(get_plan)
  [[ "${plan}" == "engineer" || "${plan}" == "conductor" ]]
}

is_tunnel_running() {
  if [ -f "${TUNNEL_PID_FILE}" ]; then
    local pid
    pid=$(cat "${TUNNEL_PID_FILE}")
    if kill -0 "${pid}" 2>/dev/null; then
      return 0
    else
      rm -f "${TUNNEL_PID_FILE}"
      return 1
    fi
  fi
  return 1
}

get_tunnel_pid() {
  if [ -f "${TUNNEL_PID_FILE}" ]; then
    cat "${TUNNEL_PID_FILE}"
  fi
}

rotate_tunnel_log() {
  if [ -f "${TUNNEL_LOG_FILE}" ]; then
    local size
    size=$(stat -f%z "${TUNNEL_LOG_FILE}" 2>/dev/null || stat -c%s "${TUNNEL_LOG_FILE}" 2>/dev/null || echo 0)
    if [ "${size}" -gt "${MAX_LOG_SIZE}" ]; then
      mv "${TUNNEL_LOG_FILE}" "${TUNNEL_LOG_FILE}.1"
    fi
  fi
}

start_tunnel_bg() {
  if is_tunnel_running; then
    local pid
    pid=$(get_tunnel_pid)
    ok "Tunnel is already running ${DIM}(PID ${pid})${NC}"
    return 0
  fi

  if ! is_paid_plan; then
    echo ""
    echo -e "  ${YELLOW}${ICON_TUNNEL} Remote monitoring${NC} requires an ${BOLD}Engineer${NC} or ${BOLD}Conductor${NC} plan."
    echo -e "  ${DIM}Upgrade at${NC} ${CYAN}https://dejajs.com/pricing${NC}"
    return 1
  fi

  if ! check_cloudflared; then
    return 1
  fi

  local WS_PORT="${VITE_WS_PORT:-8082}"
  mkdir -p "${LOG_DIR}"
  rotate_tunnel_log
  rm -f "${TUNNEL_URL_FILE}"

  # Load tunnel token from env if available
  local tunnel_token="${CLOUDFLARE_TUNNEL_TOKEN:-}"

  if [ -n "${tunnel_token}" ]; then
    info "Starting named Cloudflare tunnel..."
    nohup cloudflared tunnel run --token "${tunnel_token}" \
      >> "${TUNNEL_LOG_FILE}" 2>&1 &
  elif [ -f "${CLOUDFLARED_YML}" ]; then
    info "Starting named Cloudflare tunnel ${DIM}(cloudflared.yml)${NC}..."
    nohup cloudflared tunnel --config "${CLOUDFLARED_YML}" run \
      >> "${TUNNEL_LOG_FILE}" 2>&1 &
  else
    info "Starting quick Cloudflare tunnel ${DIM}(ephemeral URL)${NC}..."
    nohup cloudflared tunnel --url "http://localhost:${WS_PORT}" \
      >> "${TUNNEL_LOG_FILE}" 2>&1 &
  fi

  local tunnel_pid=$!
  echo "${tunnel_pid}" > "${TUNNEL_PID_FILE}"

  # Wait for cloudflared to establish connection and print URL
  sleep 3

  # Extract URL for quick tunnels
  local url=""
  if [ -f "${TUNNEL_LOG_FILE}" ]; then
    url=$(grep -o 'https://[a-z0-9-]*\.trycloudflare\.com' "${TUNNEL_LOG_FILE}" 2>/dev/null | tail -1 || true)
    [ -n "${url}" ] && echo "${url}" > "${TUNNEL_URL_FILE}"
  fi

  if is_tunnel_running; then
    echo -e "  ${GREEN}${ICON_TUNNEL} Tunnel started${NC} ${DIM}(PID ${tunnel_pid})${NC}"
    if [ -n "${url}" ]; then
      echo -e "    ${DIM}URL${NC}       ${CYAN}${url}${NC}"
    elif [ -n "${tunnel_token}" ] || [ -f "${CLOUDFLARED_YML}" ]; then
      echo -e "    ${DIM}URL${NC}       ${CYAN}wss://ws.dejajs.com${NC}"
    fi
    echo -e "    ${DIM}Logs${NC}      deja tunnel logs"
  else
    err "Tunnel failed to start. Check logs: deja tunnel logs"
    rm -f "${TUNNEL_PID_FILE}"
    return 1
  fi
}

stop_tunnel() {
  if is_tunnel_running; then
    local pid
    pid=$(get_tunnel_pid)
    kill "${pid}" 2>/dev/null || true
    sleep 1
    rm -f "${TUNNEL_PID_FILE}" "${TUNNEL_URL_FILE}"
    ok "Tunnel stopped."
  fi
}

# ======================================================================
# Interactive REPL
# ======================================================================

INTERACTIVE_PID=""

handle_repl_command() {
  local cmd="$1"
  case "${cmd}" in
    exit|quit)
      return 1  # signal to exit the REPL loop
      ;;
    help)
      echo ""
      echo -e "  ${BOLD}Interactive Commands${NC}"
      echo -e "    ${CYAN}exit${NC}    Stop the server and exit"
      echo -e "    ${CYAN}help${NC}    Show this help"
      echo ""
      return 0
      ;;
    "")
      # Empty input, ignore
      return 0
      ;;
    *)
      warn "Unknown command: ${cmd}"
      echo -e "  ${DIM}Type ${CYAN}help${NC}${DIM} for available commands${NC}"
      return 0
      ;;
  esac
}

shutdown_server() {
  if [ -n "${INTERACTIVE_PID}" ] && kill -0 "${INTERACTIVE_PID}" 2>/dev/null; then
    echo ""
    info "Stopping server ${DIM}(PID ${INTERACTIVE_PID})${NC}..."
    kill "${INTERACTIVE_PID}" 2>/dev/null || true

    # Wait up to 12 seconds for graceful shutdown
    local waited=0
    while [ ${waited} -lt 12 ]; do
      if ! kill -0 "${INTERACTIVE_PID}" 2>/dev/null; then
        break
      fi
      sleep 1
      waited=$((waited + 1))
    done

    # Force kill if still running
    if kill -0 "${INTERACTIVE_PID}" 2>/dev/null; then
      warn "Forcing shutdown..."
      kill -9 "${INTERACTIVE_PID}" 2>/dev/null || true
      sleep 1
    fi

    ok "Server stopped."
  fi
  rm -f "${PID_FILE}"
  INTERACTIVE_PID=""
  stop_tunnel
}

cmd_start_interactive() {
  check_installed

  if is_running; then
    local pid
    pid=$(get_pid)
    warn "Server is already running in the background ${DIM}(PID ${pid})${NC}"
    info "Stop it first with: ${CYAN}deja stop${NC}"
    return 1
  fi

  check_env

  # Load env vars into shell for tunnel token access
  if [ -f "${ENV_FILE}" ]; then
    # shellcheck disable=SC1090
    set -a; source "${ENV_FILE}" 2>/dev/null || true; set +a
  fi

  echo ""
  echo -e "  ${GREEN}${ICON_SERVER} DEJA.js Server${NC} ${DIM}v$(get_version)${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  echo -e "  ${DIM}Type ${CYAN}exit${NC}${DIM} to stop · ${CYAN}help${NC}${DIM} for commands${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  echo ""

  # CWD must be ~/.deja so dotenv/config finds .env
  cd "${DEJA_DIR}"

  # Start server as a child process with output going to terminal
  node "${ENTRY}" &
  INTERACTIVE_PID=$!
  echo "${INTERACTIVE_PID}" > "${PID_FILE}"

  # Trap Ctrl+C and terminal signals for clean shutdown
  trap 'shutdown_server; exit 0' INT TERM

  # Brief pause to let the server initialize and print startup messages
  sleep 1

  # Verify the server actually started
  if ! kill -0 "${INTERACTIVE_PID}" 2>/dev/null; then
    err "Server failed to start."
    rm -f "${PID_FILE}"
    INTERACTIVE_PID=""
    exit 1
  fi

  # Start tunnel for paid plans (background, non-blocking)
  start_tunnel_bg

  # REPL loop: read commands while server is running
  while kill -0 "${INTERACTIVE_PID}" 2>/dev/null; do
    # read with 1-second timeout so we can check if server is still alive
    if read -r -t 1 input 2>/dev/null; then
      if ! handle_repl_command "${input}"; then
        # Command handler returned non-zero — exit requested
        shutdown_server
        echo ""
        exit 0
      fi
    fi
  done

  # If we get here, the server exited on its own
  echo ""
  if [ ! -f "${PID_FILE}" ]; then
    # PID file was cleaned up — likely stopped via `deja stop` from another terminal
    ok "Server stopped."
  else
    warn "Server process exited unexpectedly."
    rm -f "${PID_FILE}"
  fi
  INTERACTIVE_PID=""
  exit 0
}

# ======================================================================
# Commands
# ======================================================================

cmd_start() {
  local background=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --background|-b|--bg)
        background=true
        ;;
      *) ;;
    esac
    shift
  done

  if [ "${background}" = true ]; then
    cmd_start_background
  else
    cmd_start_interactive
  fi
}

cmd_start_background() {
  check_installed

  if is_running; then
    local pid
    pid=$(get_pid)
    ok "Server is already running ${DIM}(PID ${pid})${NC}"
    return 0
  fi

  check_env
  rotate_log
  mkdir -p "${LOG_DIR}"

  # Load env vars into shell for tunnel token access
  if [ -f "${ENV_FILE}" ]; then
    # shellcheck disable=SC1090
    set -a; source "${ENV_FILE}" 2>/dev/null || true; set +a
  fi

  info "Starting DEJA.js server..."

  # CWD must be ~/.deja so dotenv/config finds .env
  cd "${DEJA_DIR}"
  nohup node "${ENTRY}" >> "${LOG_FILE}" 2>&1 &
  local pid=$!
  echo "${pid}" > "${PID_FILE}"

  # Verify the process started
  sleep 1
  if kill -0 "${pid}" 2>/dev/null; then
    echo ""
    echo -e "  ${GREEN}${ICON_SERVER} Server started${NC} ${DIM}(PID ${pid})${NC}"
    echo ""
    echo -e "    ${DIM}Version${NC}   $(get_version)"
    echo -e "    ${DIM}Logs${NC}      deja logs -f"
    echo -e "    ${DIM}Status${NC}    deja status"
    echo ""
  else
    rm -f "${PID_FILE}"
    err "Server failed to start. Check logs:"
    echo -e "    ${LOG_FILE}"
    exit 1
  fi

  # Start tunnel for paid plans
  start_tunnel_bg
}

cmd_stop() {
  if ! is_running; then
    warn "Server is not running."
    return 0
  fi

  local pid
  pid=$(get_pid)
  info "Stopping server ${DIM}(PID ${pid})${NC}..."

  # Graceful shutdown
  kill "${pid}" 2>/dev/null || true

  # Wait up to 12 seconds for graceful shutdown
  local waited=0
  while [ ${waited} -lt 12 ]; do
    if ! kill -0 "${pid}" 2>/dev/null; then
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done

  # Force kill if still running
  if kill -0 "${pid}" 2>/dev/null; then
    warn "Forcing shutdown..."
    kill -9 "${pid}" 2>/dev/null || true
    sleep 1
  fi

  rm -f "${PID_FILE}"
  ok "Server stopped."
  stop_tunnel
}

cmd_restart() {
  cmd_stop
  cmd_start "$@"
}

cmd_status() {
  echo ""
  echo -e "  ${BOLD}${ICON_SERVER} DEJA.js Server${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"

  # Version
  local version
  version=$(get_version)
  echo -e "  ${DIM}Version${NC}     ${version}"

  # Process state
  if is_running; then
    local pid
    pid=$(get_pid)
    echo -e "  ${DIM}Status${NC}      ${GREEN}${ICON_RUNNING} running${NC} ${DIM}(PID ${pid})${NC}"
  else
    echo -e "  ${DIM}Status${NC}      ${RED}${ICON_STOPPED} stopped${NC}"
  fi

  # Config
  if [ -f "${CONFIG_FILE}" ]; then
    local uid layout_id
    uid=$(grep -o '"uid"[[:space:]]*:[[:space:]]*"[^"]*"' "${CONFIG_FILE}" | sed 's/.*"uid"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "")
    layout_id=$(grep -o '"layoutId"[[:space:]]*:[[:space:]]*"[^"]*"' "${CONFIG_FILE}" | sed 's/.*"layoutId"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "")
    if [ -n "${uid}" ]; then
      echo -e "  ${DIM}Account${NC}     ${uid}"
    fi
    if [ -n "${layout_id}" ]; then
      echo -e "  ${DIM}Layout${NC}      ${layout_id}"
    fi
  fi

  echo ""
  echo -e "  ${BOLD}${ICON_CONFIG} Connections${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"

  # WebSocket
  if [ -f "${ENV_FILE}" ]; then
    local ws_port ws_enabled
    ws_port=$(grep '^VITE_WS_PORT=' "${ENV_FILE}" | cut -d'=' -f2 || echo "8082")
    ws_port="${ws_port:-8082}"
    ws_enabled=$(grep '^ENABLE_WS=' "${ENV_FILE}" | cut -d'=' -f2 || echo "true")
    ws_enabled="${ws_enabled:-true}"
    if [ "${ws_enabled}" != "false" ]; then
      echo -e "  ${ICON_WS} ${DIM}WebSocket${NC}   ${CYAN}ws://localhost:${ws_port}${NC}"
    else
      echo -e "  ${ICON_WS} ${DIM}WebSocket${NC}   ${DIM}disabled${NC}"
    fi

    # MQTT
    local mqtt_enabled
    mqtt_enabled=$(grep '^ENABLE_MQTT=' "${ENV_FILE}" | cut -d'=' -f2 || echo "false")
    mqtt_enabled="${mqtt_enabled:-false}"
    if [ "${mqtt_enabled}" = "true" ]; then
      echo -e "  ${ICON_CLOUD} ${DIM}MQTT${NC}        ${GREEN}enabled${NC}"
    fi

    # Cloud
    local cloud_enabled
    cloud_enabled=$(grep '^ENABLE_DEJACLOUD=' "${ENV_FILE}" | cut -d'=' -f2 || echo "false")
    cloud_enabled="${cloud_enabled:-false}"
    if [ "${cloud_enabled}" = "true" ]; then
      echo -e "  ${ICON_CLOUD} ${DIM}DEJA Cloud${NC}  ${GREEN}connected${NC}"
    fi
  fi

  # Serial ports
  local ports=()
  for p in /dev/ttyUSB* /dev/ttyACM* /dev/ttyAMA* /dev/tty.usbmodem* /dev/tty.usbserial*; do
    [ -e "${p}" ] && ports+=("${p}")
  done
  if [ ${#ports[@]} -gt 0 ]; then
    for port in "${ports[@]}"; do
      echo -e "  ${ICON_SERIAL} ${DIM}Serial${NC}      ${port}"
    done
  else
    echo -e "  ${ICON_SERIAL} ${DIM}Serial${NC}      ${DIM}none detected${NC}"
  fi

  echo ""
  echo -e "  ${BOLD}${ICON_TUNNEL} Remote Monitoring${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  if is_tunnel_running; then
    local tunnel_pid
    tunnel_pid=$(get_tunnel_pid)
    echo -e "  ${DIM}Tunnel${NC}      ${GREEN}${ICON_RUNNING} running${NC} ${DIM}(PID ${tunnel_pid})${NC}"
    if [ -f "${TUNNEL_URL_FILE}" ]; then
      local tunnel_url
      tunnel_url=$(cat "${TUNNEL_URL_FILE}")
      echo -e "  ${ICON_TUNNEL} ${DIM}URL${NC}         ${CYAN}${tunnel_url}${NC}"
    else
      echo -e "  ${ICON_TUNNEL} ${DIM}URL${NC}         ${CYAN}wss://ws.dejajs.com${NC}"
    fi
  else
    local plan
    plan=$(get_plan)
    if [[ "${plan}" == "engineer" || "${plan}" == "conductor" ]]; then
      echo -e "  ${DIM}Tunnel${NC}      ${RED}${ICON_STOPPED} stopped${NC} ${DIM}— run: deja tunnel start${NC}"
    else
      echo -e "  ${DIM}Tunnel${NC}      ${DIM}not available${NC} ${DIM}(upgrade to Engineer or Conductor — https://dejajs.com/pricing)${NC}"
    fi
  fi

  echo ""
  echo -e "  ${BOLD}${ICON_TRAIN} Apps${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  echo -e "  ${ICON_THROTTLE} ${DIM}Throttle${NC}    ${CYAN}https://throttle.dejajs.com${NC}"
  echo -e "  ${ICON_CLOUD} ${DIM}Cloud${NC}       ${CYAN}https://cloud.dejajs.com${NC}"
  echo -e "  ${ICON_MONITOR} ${DIM}Monitor${NC}     ${CYAN}https://monitor.dejajs.com${NC}"

  # Log file
  echo ""
  if [ -f "${LOG_FILE}" ]; then
    local log_size
    log_size=$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)
    if [ "${log_size}" -gt 1048576 ]; then
      echo -e "  ${ICON_LOG} ${DIM}Log${NC}  ${LOG_FILE} ${DIM}($((log_size / 1048576))MB)${NC}"
    elif [ "${log_size}" -gt 1024 ]; then
      echo -e "  ${ICON_LOG} ${DIM}Log${NC}  ${LOG_FILE} ${DIM}($((log_size / 1024))KB)${NC}"
    else
      echo -e "  ${ICON_LOG} ${DIM}Log${NC}  ${LOG_FILE} ${DIM}(${log_size}B)${NC}"
    fi
  fi

  echo ""
}

cmd_logs() {
  if [ ! -f "${LOG_FILE}" ]; then
    warn "No log file found."
    return 0
  fi

  local follow=false
  local lines=50

  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--follow) follow=true ;;
      -n|--lines)
        shift
        lines="${1:-50}"
        ;;
      -n*)
        lines="${1#-n}"
        ;;
      *) ;;
    esac
    shift
  done

  if [ "${follow}" = true ]; then
    tail -n "${lines}" -f "${LOG_FILE}"
  else
    tail -n "${lines}" "${LOG_FILE}"
  fi
}

cmd_update() {
  echo ""
  echo -e "  ${ICON_UPDATE} ${BOLD}Checking for updates...${NC}"

  local current_version
  current_version=$(get_version)

  # Check if server is running (will restart after update)
  local was_running=false
  if is_running; then
    was_running=true
    cmd_stop
  fi

  # Download latest tarball from install API
  local tarball_url="${INSTALL_BASE_URL}/releases/latest/deja-server.tar.gz"
  local tmp_dir
  tmp_dir=$(mktemp -d)

  info "Downloading latest release..."
  curl -fsSL "${tarball_url}" -o "${tmp_dir}/deja-server.tar.gz" || {
    err "Failed to download update. Check your internet connection."
    rm -rf "${tmp_dir}"
    exit 1
  }

  # Extract and replace
  info "Installing..."
  mkdir -p "${SERVER_DIR}"
  tar -xzf "${tmp_dir}/deja-server.tar.gz" -C "${SERVER_DIR}"
  rm -rf "${tmp_dir}"

  # Read updated version
  local latest_version
  latest_version=$(get_version)

  if [ "${current_version}" = "${latest_version}" ]; then
    ok "Already up to date ${DIM}(${current_version})${NC}"
  else
    # Install/update native dependencies
    info "Installing dependencies..."
    cd "${SERVER_DIR}" && npm install --production --silent 2>/dev/null

    ok "Updated: ${current_version} ${ICON_ARROW} ${latest_version}"
  fi

  # Update CLI itself
  local cli_url="${INSTALL_BASE_URL}/releases/latest/deja"
  info "Updating CLI..."
  curl -fsSL "${cli_url}" -o "${DEJA_BIN}/deja" || {
    warn "Failed to update CLI. Continuing with current version."
  }
  chmod +x "${DEJA_BIN}/deja"

  # Restart if was running
  if [ "${was_running}" = true ]; then
    cmd_start
  fi
  echo ""
}

cmd_tunnel() {
  local subcmd="${1:-start}"
  shift || true

  case "${subcmd}" in
    start)
      if [ -f "${ENV_FILE}" ]; then
        # shellcheck disable=SC1090
        set -a; source "${ENV_FILE}" 2>/dev/null || true; set +a
      fi
      echo ""
      start_tunnel_bg
      echo ""
      ;;
    stop)
      echo ""
      if is_tunnel_running; then
        stop_tunnel
      else
        warn "Tunnel is not running."
      fi
      echo ""
      ;;
    status)
      echo ""
      echo -e "  ${BOLD}${ICON_TUNNEL} Tunnel Status${NC}"
      echo -e "  ${DIM}──────────────────────────────${NC}"
      if is_tunnel_running; then
        local pid
        pid=$(get_tunnel_pid)
        echo -e "  ${DIM}Status${NC}    ${GREEN}${ICON_RUNNING} running${NC} ${DIM}(PID ${pid})${NC}"
        if [ -f "${TUNNEL_URL_FILE}" ]; then
          local url
          url=$(cat "${TUNNEL_URL_FILE}")
          echo -e "  ${DIM}URL${NC}       ${CYAN}${url}${NC}"
        fi
      else
        local plan
        plan=$(get_plan)
        echo -e "  ${DIM}Status${NC}    ${RED}${ICON_STOPPED} stopped${NC}"
        if [[ "${plan}" != "engineer" && "${plan}" != "conductor" ]]; then
          echo -e "  ${DIM}Plan${NC}      ${plan:-unknown} ${DIM}(upgrade to enable — https://dejajs.com/pricing)${NC}"
        fi
      fi
      echo ""
      ;;
    logs)
      local lines="${1:-50}"
      if [ -f "${TUNNEL_LOG_FILE}" ]; then
        tail -n "${lines}" "${TUNNEL_LOG_FILE}"
      else
        warn "No tunnel log found at ${TUNNEL_LOG_FILE}"
      fi
      ;;
    *)
      echo ""
      echo -e "  ${DIM}Usage:${NC} deja tunnel ${CYAN}[start|stop|status|logs]${NC}"
      echo ""
      ;;
  esac
}

cmd_help() {
  echo ""
  echo -e "  ${BOLD}${ICON_SERVER} DEJA.js Server CLI${NC}"
  echo ""
  echo -e "  ${DIM}Usage:${NC} deja ${CYAN}<command>${NC} [options]"
  echo ""
  echo -e "  ${BOLD}Commands${NC}"
  echo -e "    ${CYAN}start${NC}          Start the server (interactive mode)"
  echo -e "    ${CYAN}start -b${NC}       Start the server in the background"
  echo -e "    ${CYAN}stop${NC}           Stop the server"
  echo -e "    ${CYAN}restart${NC}        Restart the server"
  echo -e "    ${CYAN}status${NC}         Show server status and connections"
  echo -e "    ${CYAN}logs${NC} [-f]      View server logs (-f to follow)"
  echo -e "    ${CYAN}update${NC}         Update to the latest version"
  echo ""
  echo -e "  ${BOLD}${ICON_TUNNEL} Remote Monitoring${NC} ${DIM}(Engineer & Conductor plans)${NC}"
  echo -e "    ${CYAN}tunnel start${NC}   Start Cloudflare tunnel for remote monitor access"
  echo -e "    ${CYAN}tunnel stop${NC}    Stop the tunnel"
  echo -e "    ${CYAN}tunnel status${NC}  Show tunnel status and URL"
  echo -e "    ${CYAN}tunnel logs${NC}    View tunnel logs"
  echo ""
  echo -e "  ${BOLD}Options${NC}"
  echo -e "    ${DIM}--version${NC}      Show installed version"
  echo -e "    ${DIM}--help, -h${NC}     Show this help"
  echo ""
  echo -e "  ${BOLD}Interactive Mode${NC}"
  echo -e "    When started without ${DIM}-b${NC}, the server runs in the foreground."
  echo -e "    Type ${CYAN}exit${NC} to stop the server, or press ${CYAN}Ctrl+C${NC}."
  echo ""
  echo -e "  ${ICON_CONFIG} Config  ${DIM}${DEJA_DIR}/${NC}"
  echo -e "  ${ICON_LOG} Logs    ${DIM}${LOG_FILE}${NC}"
  echo ""
}

# ======================================================================
# Main
# ======================================================================

case "${1:-}" in
  start)    shift; cmd_start "$@" ;;
  stop)     shift; cmd_stop "$@" ;;
  restart)  shift; cmd_restart "$@" ;;
  status)   shift; cmd_status "$@" ;;
  logs)     shift; cmd_logs "$@" ;;
  update)   shift; cmd_update "$@" ;;
  tunnel)   shift; cmd_tunnel "$@" ;;
  --version|-v)
    echo "deja $(get_version)"
    ;;
  --help|-h|help)
    cmd_help
    ;;
  "")
    cmd_help
    ;;
  *)
    err "Unknown command: $1"
    cmd_help
    exit 1
    ;;
esac
