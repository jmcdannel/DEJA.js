# ======================================================================
# 🔧 Helpers
# ======================================================================

get_version() {
  if [ -f "${VERSION_FILE}" ]; then
    cat "${VERSION_FILE}"
  else
    echo "unknown"
  fi
}

# Check if a process is running by PID file. Returns 0 if running, 1 if not.
# Outputs the PID to stdout if running (avoids double-reading the PID file).
_check_pid_file() {
  local pid_file="$1"
  if [ -f "${pid_file}" ]; then
    local pid
    pid=$(cat "${pid_file}")
    if kill -0 "${pid}" 2>/dev/null; then
      echo "${pid}"
      return 0
    else
      rm -f "${pid_file}"
      return 1
    fi
  fi
  return 1
}

is_running() { _check_pid_file "${PID_FILE}" >/dev/null; }
get_pid()    { _check_pid_file "${PID_FILE}" 2>/dev/null || true; }

_rotate_file() {
  local file="$1"
  if [ -f "${file}" ]; then
    local size
    size=$(stat -f%z "${file}" 2>/dev/null || stat -c%s "${file}" 2>/dev/null || echo 0)
    if [ "${size}" -gt "${MAX_LOG_SIZE}" ]; then
      mv "${file}" "${file}.1"
    fi
  fi
}

rotate_log() { _rotate_file "${LOG_FILE}"; }

check_installed() {
  if [ ! -f "${ENTRY}" ]; then
    err "DEJA.js server is not installed."
    info "🚀 Run the installer: ${CYAN}curl -fsSL https://install.dejajs.com | bash${NC}"
    exit 1
  fi
}

check_env() {
  if [ ! -f "${ENV_FILE}" ]; then
    warn "No .env file found at ${ENV_FILE}"
    warn "The server may not start correctly without environment configuration."
  fi
}

# ======================================================================
# 🔒 Tunnel Helpers
# ======================================================================

check_cloudflared() {
  if ! command -v cloudflared &>/dev/null; then
    warn "cloudflared is not installed. Remote monitoring requires cloudflared."
    echo ""
    info "📦 Install it:"
    echo -e "    ${DIM}macOS:${NC}  brew install cloudflare/cloudflare/cloudflared"
    echo -e "    ${DIM}Linux:${NC}  curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg | sudo tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null"
    echo -e "           ${DIM}echo 'deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared focal main' | sudo tee /etc/apt/sources.list.d/cloudflared.list${NC}"
    echo -e "           ${DIM}sudo apt-get update && sudo apt-get install cloudflared${NC}"
    echo -e "    ${DIM}Docs:${NC}   https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/"
    return 1
  fi
  return 0
}

get_plan() {
  if [ ! -f "${CONFIG_FILE}" ]; then
    echo ""
    return
  fi
  node -e "
    try {
      const c = JSON.parse(require('fs').readFileSync('${CONFIG_FILE}', 'utf8'));
      console.log(c.subscription?.plan || '');
    } catch(e) { console.log(''); }
  " 2>/dev/null || echo ""
}

is_paid_plan() {
  local plan
  plan=$(get_plan)
  [[ "${plan}" == "engineer" || "${plan}" == "conductor" ]]
}

is_tunnel_running() { _check_pid_file "${TUNNEL_PID_FILE}" >/dev/null; }
get_tunnel_pid()    { _check_pid_file "${TUNNEL_PID_FILE}" 2>/dev/null || true; }
rotate_tunnel_log() { _rotate_file "${TUNNEL_LOG_FILE}"; }

start_tunnel_bg() {
  if is_tunnel_running; then
    local pid
    pid=$(get_tunnel_pid)
    ok "Tunnel is already running ${DIM}(PID ${pid})${NC}"
    return 0
  fi

  if ! is_paid_plan; then
    echo ""
    echo -e "  🔒 ${YELLOW}Remote monitoring${NC} requires an ${BOLD}Engineer${NC} or ${BOLD}Conductor${NC} plan."
    echo -e "  ${DIM}Upgrade at${NC} ${CYAN}https://dejajs.com/pricing${NC}"
    return 1
  fi

  if ! check_cloudflared; then
    return 1
  fi

  local WS_PORT="${VITE_WS_PORT:-8082}"
  mkdir -p "${LOG_DIR}"
  rotate_tunnel_log
  rm -f "${TUNNEL_URL_FILE}"

  # Load tunnel token from env if available
  local tunnel_token="${CLOUDFLARE_TUNNEL_TOKEN:-}"

  if [ -n "${tunnel_token}" ]; then
    info "🔒 Starting named Cloudflare tunnel..."
    nohup cloudflared tunnel run --token "${tunnel_token}" \
      >> "${TUNNEL_LOG_FILE}" 2>&1 &
  elif [ -f "${CLOUDFLARED_YML}" ]; then
    info "🔒 Starting named Cloudflare tunnel ${DIM}(cloudflared.yml)${NC}..."
    nohup cloudflared tunnel --config "${CLOUDFLARED_YML}" run \
      >> "${TUNNEL_LOG_FILE}" 2>&1 &
  else
    info "🔒 Starting quick Cloudflare tunnel ${DIM}(ephemeral URL)${NC}..."
    nohup cloudflared tunnel --url "http://localhost:${WS_PORT}" \
      >> "${TUNNEL_LOG_FILE}" 2>&1 &
  fi

  local tunnel_pid=$!
  echo "${tunnel_pid}" > "${TUNNEL_PID_FILE}"

  # Wait for cloudflared to establish connection and print URL
  sleep 3

  # Extract URL for quick tunnels
  local url=""
  if [ -f "${TUNNEL_LOG_FILE}" ]; then
    url=$(grep -o 'https://[a-z0-9-]*\.trycloudflare\.com' "${TUNNEL_LOG_FILE}" 2>/dev/null | tail -1 || true)
    [ -n "${url}" ] && echo "${url}" > "${TUNNEL_URL_FILE}"
  fi

  if is_tunnel_running; then
    echo -e "  🔒 ${GREEN}Tunnel started${NC} ${DIM}(PID ${tunnel_pid})${NC}"
    if [ -n "${url}" ]; then
      echo -e "    🌐 ${DIM}URL${NC}       ${CYAN}${url}${NC}"
    elif [ -n "${tunnel_token}" ] || [ -f "${CLOUDFLARED_YML}" ]; then
      echo -e "    🌐 ${DIM}URL${NC}       ${CYAN}wss://ws.dejajs.com${NC}"
    fi
    echo -e "    📋 ${DIM}Logs${NC}      deja tunnel logs"
  else
    err "Tunnel failed to start. Check logs: deja tunnel logs"
    rm -f "${TUNNEL_PID_FILE}"
    return 1
  fi
}

stop_tunnel() {
  if is_tunnel_running; then
    local pid
    pid=$(get_tunnel_pid)
    kill "${pid}" 2>/dev/null || true
    sleep 1
    rm -f "${TUNNEL_PID_FILE}" "${TUNNEL_URL_FILE}"
    ok "Tunnel stopped 🔒"
  fi
}

# ======================================================================
# 🖥️ Interactive TUI
# ======================================================================

cmd_start_interactive() {
  check_installed

  if is_running; then
    local pid
    pid=$(get_pid)
    warn "Server is already running in the background ${DIM}(PID ${pid})${NC}"
    info "🛑 Stop it first with: ${CYAN}deja stop${NC}"
    return 1
  fi

  check_env

  # Load env vars into shell so they're visible to the Node.js TUI process
  if [ -f "${ENV_FILE}" ]; then
    # shellcheck disable=SC1090
    set -a; source "${ENV_FILE}" 2>/dev/null || true; set +a
  fi

  echo ""
  print_banner
  echo ""
  echo -e "  ${BOLD}🚂 DCC-EX JavaScript API${NC} — Starting..."
  echo ""

  # Launch the interactive TUI.
  # Defaults to ink; set DEJA_UI to use a different renderer.
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local ui="${DEJA_UI:-ink}"
  exec node "${script_dir}/deja-ui-${ui}.mjs"
}

# ======================================================================
# 🎮 Commands
# ======================================================================

cmd_start() {
  local background=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --background|-b|--bg)
        background=true
        ;;
      *) ;;
    esac
    shift
  done

  if [ "${background}" = true ]; then
    cmd_start_background
  else
    cmd_start_interactive
  fi
}

cmd_start_background() {
  echo ""
  print_banner
  echo ""
  echo -e "  ${BOLD}🚂 DCC-EX JavaScript API${NC} — Starting..."
  echo ""

  check_installed

  if is_running; then
    local pid
    pid=$(get_pid)
    ok "Server is already running ${DIM}(PID ${pid})${NC}"
    return 0
  fi

  check_env
  rotate_log
  mkdir -p "${LOG_DIR}"

  # Load env vars into shell for tunnel token access
  if [ -f "${ENV_FILE}" ]; then
    # shellcheck disable=SC1090
    set -a; source "${ENV_FILE}" 2>/dev/null || true; set +a
  fi

  info "🚀 Starting DEJA.js server..."

  # CWD must be ~/.deja so dotenv/config finds .env
  cd "${DEJA_DIR}"
  nohup node "${ENTRY}" >> "${LOG_FILE}" 2>&1 &
  local pid=$!
  echo "${pid}" > "${PID_FILE}"

  # Verify the process started
  sleep 1
  if kill -0 "${pid}" 2>/dev/null; then
    echo ""
    echo -e "  ⚡ ${GREEN}${BOLD}Server started${NC} ${DIM}(PID ${pid})${NC}"
    echo ""
    echo -e "    📦 ${DIM}Version${NC}   $(get_version)"
    echo -e "    📋 ${DIM}Logs${NC}      deja logs -f"
    echo -e "    📊 ${DIM}Status${NC}    deja status"
    echo ""
  else
    rm -f "${PID_FILE}"
    err "Server failed to start. Check logs:"
    echo -e "    📋 ${LOG_FILE}"
    exit 1
  fi

  # Start tunnel for paid plans
  start_tunnel_bg
}

cmd_stop() {
  if ! is_running; then
    warn "Server is not running."
    return 0
  fi

  local pid
  pid=$(get_pid)
  info "🛑 Stopping server ${DIM}(PID ${pid})${NC}..."

  # Graceful shutdown
  kill "${pid}" 2>/dev/null || true

  # Wait up to 12 seconds for graceful shutdown
  local waited=0
  while [ ${waited} -lt 12 ]; do
    if ! kill -0 "${pid}" 2>/dev/null; then
      break
    fi
    sleep 1
    waited=$((waited + 1))
  done

  # Force kill if still running
  if kill -0 "${pid}" 2>/dev/null; then
    warn "💀 Forcing shutdown..."
    kill -9 "${pid}" 2>/dev/null || true
    sleep 1
  fi

  rm -f "${PID_FILE}"
  ok "Server stopped 🛑"
  stop_tunnel
}

cmd_restart() {
  cmd_stop
  cmd_start "$@"
}

cmd_status() {
  echo ""
  echo -e "  ${BOLD}⚡ DEJA.js Server${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"

  # Version
  local version
  version=$(get_version)
  echo -e "  📦 ${DIM}Version${NC}     ${version}"

  # Process state
  if is_running; then
    local pid
    pid=$(get_pid)
    echo -e "  🟢 ${DIM}Status${NC}      ${GREEN}running${NC} ${DIM}(PID ${pid})${NC}"
  else
    echo -e "  🔴 ${DIM}Status${NC}      ${RED}stopped${NC}"
  fi

  # Config
  if [ -f "${CONFIG_FILE}" ]; then
    local uid layout_id
    uid=$(grep -o '"uid"[[:space:]]*:[[:space:]]*"[^"]*"' "${CONFIG_FILE}" | sed 's/.*"uid"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "")
    layout_id=$(grep -o '"layoutId"[[:space:]]*:[[:space:]]*"[^"]*"' "${CONFIG_FILE}" | sed 's/.*"layoutId"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || echo "")
    if [ -n "${uid}" ]; then
      echo -e "  🪪 ${DIM}Account${NC}     ${uid}"
    fi
    if [ -n "${layout_id}" ]; then
      echo -e "  🏷️  ${DIM}Layout${NC}      ${layout_id}"
    fi
  fi

  echo ""
  echo -e "  ${BOLD}🔌 Connections${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"

  # Source .env once to read all connection settings
  local ws_port="${VITE_WS_PORT:-8082}"
  local ws_enabled="${ENABLE_WS:-true}"
  local mqtt_enabled="${ENABLE_MQTT:-false}"
  local cloud_enabled="${ENABLE_DEJACLOUD:-false}"
  if [ -f "${ENV_FILE}" ]; then
    # shellcheck disable=SC1090
    eval "$(grep -E '^(VITE_WS_PORT|ENABLE_WS|ENABLE_MQTT|ENABLE_DEJACLOUD)=' "${ENV_FILE}" 2>/dev/null || true)"
    ws_port="${VITE_WS_PORT:-${ws_port}}"
    ws_enabled="${ENABLE_WS:-${ws_enabled}}"
    mqtt_enabled="${ENABLE_MQTT:-${mqtt_enabled}}"
    cloud_enabled="${ENABLE_DEJACLOUD:-${cloud_enabled}}"
  fi

  if [ "${ws_enabled}" != "false" ]; then
    echo -e "  🌐 ${DIM}WebSocket${NC}   ${CYAN}ws://localhost:${ws_port}${NC}"
  else
    echo -e "  🌐 ${DIM}WebSocket${NC}   ${DIM}disabled${NC}"
  fi
  if [ "${mqtt_enabled}" = "true" ]; then
    echo -e "  📡 ${DIM}MQTT${NC}        ${GREEN}enabled${NC}"
  fi
  if [ "${cloud_enabled}" = "true" ]; then
    echo -e "  ☁️  ${DIM}DEJA Cloud${NC}  ${GREEN}connected${NC}"
  fi

  # Serial ports
  local ports=()
  for p in /dev/ttyUSB* /dev/ttyACM* /dev/ttyAMA* /dev/tty.usbmodem* /dev/tty.usbserial*; do
    [ -e "${p}" ] && ports+=("${p}")
  done
  if [ ${#ports[@]} -gt 0 ]; then
    for port in "${ports[@]}"; do
      echo -e "  🔌 ${DIM}Serial${NC}      ${port}"
    done
  else
    echo -e "  🔌 ${DIM}Serial${NC}      ${DIM}none detected${NC}"
  fi

  echo ""
  echo -e "  ${BOLD}🔒 Remote Monitoring${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  if is_tunnel_running; then
    local tunnel_pid
    tunnel_pid=$(get_tunnel_pid)
    echo -e "  🟢 ${DIM}Tunnel${NC}      ${GREEN}running${NC} ${DIM}(PID ${tunnel_pid})${NC}"
    if [ -f "${TUNNEL_URL_FILE}" ]; then
      local tunnel_url
      tunnel_url=$(cat "${TUNNEL_URL_FILE}")
      echo -e "  🌐 ${DIM}URL${NC}         ${CYAN}${tunnel_url}${NC}"
    else
      echo -e "  🌐 ${DIM}URL${NC}         ${CYAN}wss://ws.dejajs.com${NC}"
    fi
  else
    if is_paid_plan; then
      echo -e "  🔴 ${DIM}Tunnel${NC}      ${RED}stopped${NC} ${DIM}— run: deja tunnel start${NC}"
    else
      echo -e "  🔴 ${DIM}Tunnel${NC}      ${DIM}not available${NC} ${DIM}(upgrade to Engineer or Conductor — https://dejajs.com/pricing)${NC}"
    fi
  fi

  echo ""
  echo -e "  ${BOLD}🚂 Apps${NC}"
  echo -e "  ${DIM}──────────────────────────────${NC}"
  echo -e "  🎮 ${DIM}Throttle${NC}    ${CYAN}https://throttle.dejajs.com${NC}"
  echo -e "  ☁️  ${DIM}Cloud${NC}       ${CYAN}https://cloud.dejajs.com${NC}"
  echo -e "  📊 ${DIM}Monitor${NC}     ${CYAN}https://monitor.dejajs.com${NC}"

  # Log file
  echo ""
  if [ -f "${LOG_FILE}" ]; then
    local log_size
    log_size=$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)
    if [ "${log_size}" -gt 1048576 ]; then
      echo -e "  📋 ${DIM}Log${NC}  ${LOG_FILE} ${DIM}($((log_size / 1048576))MB)${NC}"
    elif [ "${log_size}" -gt 1024 ]; then
      echo -e "  📋 ${DIM}Log${NC}  ${LOG_FILE} ${DIM}($((log_size / 1024))KB)${NC}"
    else
      echo -e "  📋 ${DIM}Log${NC}  ${LOG_FILE} ${DIM}(${log_size}B)${NC}"
    fi
  fi

  echo ""
}

cmd_logs() {
  if [ ! -f "${LOG_FILE}" ]; then
    warn "No log file found."
    return 0
  fi

  local follow=false
  local lines=50

  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--follow) follow=true ;;
      -n|--lines)
        shift
        lines="${1:-50}"
        ;;
      -n*)
        lines="${1#-n}"
        ;;
      *) ;;
    esac
    shift
  done

  if [ "${follow}" = true ]; then
    tail -n "${lines}" -f "${LOG_FILE}"
  else
    tail -n "${lines}" "${LOG_FILE}"
  fi
}

cmd_update() {
  echo ""
  echo -e "  🔄 ${BOLD}Checking for updates...${NC}"

  local current_version
  current_version=$(get_version)

  # Check if server is running (will restart after update)
  local was_running=false
  if is_running; then
    was_running=true
    cmd_stop
  fi

  # Download latest tarball from install API
  local tarball_url="${INSTALL_BASE_URL}/releases/latest/deja-server.tar.gz"
  local tmp_dir
  tmp_dir=$(mktemp -d)
  trap "rm -rf '${tmp_dir}'" EXIT

  info "⬇️  Downloading latest release..."
  curl -fsSL "${tarball_url}" -o "${tmp_dir}/deja-server.tar.gz" || {
    err "Failed to download update. Check your internet connection."
    exit 1
  }

  info "📦 Installing..."
  mkdir -p "${SERVER_DIR}"
  tar -xzf "${tmp_dir}/deja-server.tar.gz" -C "${SERVER_DIR}"
  rm -rf "${tmp_dir}"
  trap - EXIT

  # Read updated version
  local latest_version
  latest_version=$(get_version)

  if [ "${current_version}" = "${latest_version}" ]; then
    ok "Already up to date ${DIM}(${current_version})${NC} 👍"
  else
    # Install/update native dependencies
    info "📦 Installing dependencies..."
    (cd "${SERVER_DIR}" && npm install --production --silent 2>/dev/null)

    ok "Updated: ${current_version} → ${latest_version} 🎉"
  fi

  # Update CLI itself
  local cli_url="${INSTALL_BASE_URL}/releases/latest/deja"
  info "⬇️  Updating CLI..."
  if curl -fsSL "${cli_url}" -o "${DEJA_BIN}/deja"; then
    chmod +x "${DEJA_BIN}/deja"
    ok "CLI updated"
  else
    warn "Failed to update CLI. Continuing with current version."
  fi

  # Restart if was running
  if [ "${was_running}" = true ]; then
    cmd_start
  fi
  echo ""
}

cmd_tunnel() {
  local subcmd="${1:-start}"
  shift || true

  case "${subcmd}" in
    start)
      if [ -f "${ENV_FILE}" ]; then
        # shellcheck disable=SC1090
        set -a; source "${ENV_FILE}" 2>/dev/null || true; set +a
      fi
      echo ""
      start_tunnel_bg
      echo ""
      ;;
    stop)
      echo ""
      if is_tunnel_running; then
        stop_tunnel
      else
        warn "Tunnel is not running."
      fi
      echo ""
      ;;
    status)
      echo ""
      echo -e "  ${BOLD}🔒 Tunnel Status${NC}"
      echo -e "  ${DIM}──────────────────────────────${NC}"
      if is_tunnel_running; then
        local pid
        pid=$(get_tunnel_pid)
        echo -e "  🟢 ${DIM}Status${NC}    ${GREEN}running${NC} ${DIM}(PID ${pid})${NC}"
        if [ -f "${TUNNEL_URL_FILE}" ]; then
          local url
          url=$(cat "${TUNNEL_URL_FILE}")
          echo -e "  🌐 ${DIM}URL${NC}       ${CYAN}${url}${NC}"
        fi
      else
        echo -e "  🔴 ${DIM}Status${NC}    ${RED}stopped${NC}"
        if ! is_paid_plan; then
          echo -e "  💳 ${DIM}Plan${NC}      ${DIM}upgrade to enable — https://dejajs.com/pricing${NC}"
        fi
      fi
      echo ""
      ;;
    logs)
      local lines="${1:-50}"
      if [ -f "${TUNNEL_LOG_FILE}" ]; then
        tail -n "${lines}" "${TUNNEL_LOG_FILE}"
      else
        warn "No tunnel log found at ${TUNNEL_LOG_FILE}"
      fi
      ;;
    *)
      echo ""
      echo -e "  ${DIM}Usage:${NC} deja tunnel ${CYAN}[start|stop|status|logs]${NC}"
      echo ""
      ;;
  esac
}

# ======================================================================
# Deploy — flash firmware to Arduino or Pico W device
# ======================================================================

cmd_deploy() {
  info "🚀 DEJA.js Device Deploy"
  echo ""

  # Check if running from monorepo (development) or distribution
  local SCRIPT_DIR
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local MONOREPO_IO="${SCRIPT_DIR}/../io"

  if [[ -d "$MONOREPO_IO" && -f "$MONOREPO_IO/package.json" ]]; then
    # Monorepo mode: run deploy script via tsx
    info "Running from monorepo..."
    cd "$MONOREPO_IO"

    # Ensure dependencies are installed
    if [[ ! -d "node_modules" ]]; then
      info "Installing io/ dependencies..."
      pnpm install 2>/dev/null || npm install 2>/dev/null
    fi

    exec npx tsx ./scripts/deploy.ts "$@"
  elif [[ -f "${SERVER_DIR}/deploy.js" ]]; then
    # Distribution mode: run bundled deploy script
    exec node "${SERVER_DIR}/deploy.js" "$@"
  else
    err "Deploy not available."
    echo ""
    echo -e "  ${DIM}The deploy command requires either:${NC}"
    echo -e "  • Running from the DEJA.js monorepo, or"
    echo -e "  • A server version that includes deploy support"
    echo ""
    echo -e "  Run ${CYAN}deja update${NC} to get the latest version."
    exit 1
  fi
}

