#!/usr/bin/env bash
# 🚂 scripts/deja — DEJA.js Server CLI
# Manages the DEJA.js server as a native Node.js process.
# Install location: ~/.deja/bin/deja
#
# Override install directory with DEJA_DIR env var:
#   DEJA_DIR=./tmp/test-deja ./scripts/deja start

set -euo pipefail

DEJA_DIR="${DEJA_DIR:-$HOME/.deja}"
SERVER_DIR="${DEJA_DIR}/server"
PID_FILE="${DEJA_DIR}/server.pid"
LOG_DIR="${DEJA_DIR}/logs"
LOG_FILE="${LOG_DIR}/server.log"
VERSION_FILE="${SERVER_DIR}/version.txt"
CONFIG_FILE="${DEJA_DIR}/config.json"
ENV_FILE="${DEJA_DIR}/.env"
ENTRY="${SERVER_DIR}/index.js"
INSTALL_BASE_URL="https://install.dejajs.com"

# 🔒 Tunnel
TUNNEL_PID_FILE="${DEJA_DIR}/tunnel.pid"
TUNNEL_LOG_FILE="${LOG_DIR}/tunnel.log"
TUNNEL_URL_FILE="${DEJA_DIR}/tunnel.url"
CLOUDFLARED_YML="${DEJA_DIR}/cloudflared.yml"

# Max log file size before rotation (10MB)
MAX_LOG_SIZE=10485760

# --- Colors & Styles ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

info()  { echo -e "  💬 ${BLUE}$*${NC}"; }
ok()    { echo -e "  ✅ ${GREEN}$*${NC}"; }
warn()  { echo -e "  ⚠️  ${YELLOW}$*${NC}"; }
err()   { echo -e "  ❌ ${RED}$*${NC}" >&2; }

print_banner() {
  echo -e "  \033[38;2;0;232;252m██████╗ \033[38;2;0;195;245m███████╗\033[38;2;10;160;235m     ██╗\033[38;2;25;130;220m █████╗         \033[38;2;255;0;170m██╗███████╗\033[0m"
  echo -e "  \033[38;2;0;232;252m██╔══██╗\033[38;2;0;195;245m██╔════╝\033[38;2;10;160;235m     ██║\033[38;2;25;130;220m██╔══██╗        \033[38;2;255;0;170m██║██╔════╝\033[0m"
  echo -e "  \033[38;2;0;232;252m██║  ██║\033[38;2;0;195;245m█████╗\033[38;2;10;160;235m       ██║\033[38;2;25;130;220m███████║        \033[38;2;255;0;170m██║███████╗\033[0m"
  echo -e "  \033[38;2;0;232;252m██║  ██║\033[38;2;0;195;245m██╔══╝\033[38;2;10;160;235m  ██   ██║\033[38;2;25;130;220m██╔══██║   \033[38;2;255;0;170m     ██║╚════██║\033[0m"
  echo -e "  \033[38;2;0;232;252m██████╔╝\033[38;2;0;195;245m███████╗\033[38;2;10;160;235m╚█████╔╝\033[38;2;25;130;220m██║  ██║\033[38;2;50;255;50m██╗\033[38;2;255;0;170m╚█████╔╝███████║\033[0m"
  echo -e "  \033[38;2;0;232;252m╚═════╝ \033[38;2;0;195;245m╚══════╝\033[38;2;10;160;235m ╚════╝ \033[38;2;25;130;220m╚═╝  ╚═╝\033[38;2;50;255;50m╚═╝\033[38;2;255;0;170m ╚════╝ ╚══════╝\033[0m"
