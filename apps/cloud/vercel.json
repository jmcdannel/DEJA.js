{
  "installCommand": "corepack enable && cd ../.. && pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "crons": [
    { "path": "/api/cleanup-logs", "schedule": "0 3 * * *" }
  ]
}
