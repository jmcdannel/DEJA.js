# ── Cloud App — Serverless API Variables ─────────────────
# These are needed by Vercel Functions in apps/cloud/api/
# Set in the Vercel dashboard for deployed environments.

# Cron job authentication (vercel.json crons send this as Bearer token)
CRON_SECRET=

# Firebase Admin (server-side access for cron/API routes)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (server-side billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ENGINEER_MONTHLY=
STRIPE_PRICE_ENGINEER_ANNUAL=
STRIPE_PRICE_CONDUCTOR_MONTHLY=
STRIPE_PRICE_CONDUCTOR_ANNUAL=
