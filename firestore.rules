rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Layout ownership is keyed on UID. The layout doc must carry
    // ownerUid — backfilled by scripts/migrations/2026-04-backfill-ownerUid.mjs
    // for legacy docs and set on creation by /api/layouts/create.
    function isLayoutOwner(layoutId) {
      return isAuth()
        && get(/databases/$(database)/documents/layouts/$(layoutId)).data.ownerUid == request.auth.uid;
    }

    function isLayoutOwnerByResource(resource) {
      return isAuth() && resource.data.ownerUid == request.auth.uid;
    }

    // --- Layouts ---------------------------------------------------------
    match /layouts/{layoutId} {
      // Reads: only the owner can fetch a specific layout
      allow get: if isLayoutOwnerByResource(resource);

      // Lists: Firestore rules evaluate `resource.data.ownerUid` against
      // each candidate doc, and the query planner rejects any query whose
      // filters don't guarantee this will hold — effectively forcing
      // clients to include where('ownerUid', '==', auth.uid).
      allow list: if isAuth() && resource.data.ownerUid == request.auth.uid;

      // Creates: client writes are denied entirely. Layout creation must
      // go through /api/layouts/create which runs as the admin SDK and
      // sets ownerUid + the layoutOwners RTDB mirror atomically.
      allow create: if false;

      // Updates: layout owner only. Cannot change ownerUid.
      allow update: if isLayoutOwnerByResource(resource)
        && request.resource.data.ownerUid == resource.data.ownerUid;

      // Deletes: layout owner only.
      allow delete: if isLayoutOwnerByResource(resource);

      // All sub-collections: only the layout owner can read or write.
      // Covers turnouts, signals, effects, throttles, devices, tags,
      // routes, locos, sensors, blocks, trackDiagrams, etc.
      match /{subcollection}/{docId} {
        allow read, write: if isLayoutOwner(layoutId);
      }

      // Approval requests use a subcollection. Anyone authenticated can
      // create a request for a layout (with their own UID), but only the
      // requester or the layout owner can read/manage it.
      match /approvalRequests/{requestId} {
        allow create: if isAuth()
          && request.resource.data.requesterUid == request.auth.uid;
        allow read: if isAuth() && (
          resource.data.requesterUid == request.auth.uid
          || isLayoutOwner(layoutId)
        );
        allow update, delete: if isLayoutOwner(layoutId);
      }
    }

    // --- Users -----------------------------------------------------------
    // Users can read and write their own profile, EXCEPT the subscription
    // field — that's controlled exclusively by the Stripe webhook running
    // with the Admin SDK (which bypasses rules).
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;

      allow create: if isAuth()
        && request.auth.uid == userId
        && !('subscription' in request.resource.data);

      // Allow updates only when the subscription field is unchanged.
      // affectedKeys() returns the top-level keys that were added,
      // removed, or modified — if 'subscription' is in there, deny.
      allow update: if isAuth()
        && request.auth.uid == userId
        && !('subscription' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if false;
    }

    // --- Device pairings -------------------------------------------------
    // Only the admin SDK (via /api/devices/* routes) writes. Clients can
    // read their own pairings to render the Settings → Devices UI.
    match /devicePairings/{pairingId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // --- Device pairing codes (device-code flow) -------------------------
    // Only the admin SDK reads/writes. Clients never touch these directly;
    // pair-poll/pair-approve/pair-start go through admin-authed routes.
    match /devicePairingCodes/{codeId} {
      allow read, write: if false;
    }

    // --- Promotions ------------------------------------------------------
    // Public read (e.g., the marketing site fetches active promo codes),
    // admin SDK writes only.
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Default deny ----------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
